PORT=5000
# Replace with your MongoDB connection string (do NOT commit real credentials)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/medical_db?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d

# Notes:
# - Copy this file to `.env` and fill in real values locally.
# - Keep `.env` out of version control.