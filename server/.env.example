PORT=5000
# Replace with your MongoDB connection string. Do NOT commit secrets to git.
# Example format (use your username/password and cluster info):
# mongodb+srv://<username>:<password>@cluster0.mongodb.net/your_db?retryWrites=true&w=majority
MONGODB_URI=
JWT_SECRET=change_this_jwt_secret
JWT_EXPIRE=30d

# SMTP config for login confirmation emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
APP_NAME=Medical LMS
